},
{
code = "

markClass arabichamzacomb <anchor 0 1500> @top_arab;
markClass arabicfathacomb <anchor 0 1500> @top_arab;
markClass arabicdammacomb <anchor 0 1500> @top_arab;
markClass arabicdammatancomb <anchor 0 1500> @top_arab;
markClass arabicshaddacomb <anchor 0 1500> @top_arab;
markClass arabicalefcomb <anchor 0 1500> @top_arab;
markClass arabicsukuncomb <anchor 0 1500> @top_arab;
markClass arabicfathatancomb <anchor 0 1500> @top_arab;
markClass arabicmaddahcomb <anchor 0 1500> @top_arab;
markClass vowelsignsmallvcomb-arab <anchor 0 1500> @top_arab;
markClass vowelsigninvertedsmallvcomb-arab <anchor 0 1500> @top_arab;
markClass smallhightahcomb-arab <anchor 0 1500> @top_arab;

markClass arabichamzabelowcomb <anchor 0 -300> @bottom_arab;
markClass arabickasracomb <anchor 0 -300> @bottom_arab;
markClass alefcomb-arab <anchor 0 -300> @bottom_arab;
markClass arabickasratancomb <anchor 0 -300> @bottom_arab;";
name = Marks;
},
{
code = "

#
# Global lookup definitions
#

lookup SA_zheh { # GPOS lookup type SingleAdjustment
    pos @zhe 25;
} SA_zheh;

lookup SA_Quest { # GPOS lookup type SingleAdjustment
    lookupflag RightToLeft;
    pos arabicquestionmark -125;
} SA_Quest;

lookup SA_reh { # GPOS lookup type SingleAdjustment
    lookupflag RightToLeft;
    pos @la_reh_1 -50;
    pos @la_reh3 0;
} SA_reh;

lookup teh1 { # GSUB lookup type SingleSubstitution
    lookupflag RightToLeft;
    sub teh-arab.init by teh-arab.init.1;
    sub teh-arab.medi by teh-arab.medi.1;
    sub theh-arab.init by theh-arab.init.1;
    sub theh-arab.medi by theh-arab.medi.1;
    sub tteh-arab.init by uE025;
    sub tteh-arab.medi by uE026;
} teh1;

lookup yeh2 { # GSUB lookup type SingleSubstitution
    lookupflag RightToLeft;
    sub beh-arab.init by beh-arab.init.1;
    sub beh-arab.medi by beh-arab.medi.1;
    sub peh-arab.init by peh-arab.init.2;
    sub peh-arab.medi by peh-arab.medi.2;
    sub farsiyeh-arab.init by farsiyeh-arab.init.2;
    sub farsiyeh-arab.medi by farsiyeh-arab.medi.2;
    sub uE028 by uE047;
    sub uE029 by uE059;
} yeh2;

lookup yeh3 { # GSUB lookup type SingleSubstitution
    lookupflag RightToLeft;
    sub peh-arab.init by uE070;
    sub peh-arab.medi by uE071;
    sub farsiyeh-arab.init by uE072;
    sub farsiyeh-arab.medi by uE073;
    sub uE028 by uE074;
    sub uE029 by uE075;
} yeh3;

lookup SingleSubstitution8 { # GSUB lookup type SingleSubstitution
    lookupflag RightToLeft;
    sub alef-arab by uni0627_alt.short;
    sub alef-arab.fina by alef-arab.fina.short;
    sub lamalef-arab.isol by alef_lam-arab.init;
    sub lamalef-arab.fina by alef_lam-arab.medi;
} SingleSubstitution8;

lookup SingleSubstitution8_1 { # GSUB lookup type SingleSubstitution
    lookupflag RightToLeft;
    sub alef-arab by uni0627_alt.short;
    sub alef-arab.fina by alef-arab.fina.short;
    sub lamalef-arab.isol by alef_lam-arab.init;
    sub lamalef-arab.fina by alef_lam-arab.medi;
} SingleSubstitution8_1;

lookup SA_rehcalt { # GPOS lookup type SingleAdjustment
    lookupflag RightToLeft;
    pos @la_rehcalt -100;
    pos @la_rehcalt4 -5;
    pos @la_rehcalt3 100;
} SA_rehcalt;

lookup SingleSubstitution4 { # GSUB lookup type SingleSubstitution
    lookupflag RightToLeft;
    sub farsiyeh-arab.fina by farsiyeh-arab.fina.1;
    sub yeh-arab.fina by yeh-arab.fina.1;
    sub yehhamzaabove-arab.fina by yehhamzaabove-arab.fina.1;
    sub yehbarree-arab.fina by yehbarree-arab.2.fina;
    sub yehbarreehamzaabove-arab.fina by yehbarreehamzaabove-arab.2.fina;
    sub uE027 by uE106;
} SingleSubstitution4;

lookup SingleSubstitution4_1 { # GSUB lookup type SingleSubstitution
    lookupflag RightToLeft;
    sub farsiyeh-arab.fina by uE166;
    sub yeh-arab.fina by uE167;
    sub yehhamzaabove-arab.fina by uE168;
    sub yehbarree-arab.fina by yehbarree-arab.2.fina;
    sub yehbarreehamzaabove-arab.fina by yehbarreehamzaabove-arab.2.fina;
    sub uE027 by uE169;
} SingleSubstitution4_1;

lookup SA_dall { # GPOS lookup type SingleAdjustment
    pos arabicquestionmark -100;
} SA_dall;

lookup SA_alefmadda { # GPOS lookup type SingleAdjustment
    pos arabicquestionmark 125;
    pos @aa1 150;
    pos alefmaddaabove-arab 225;
    pos @aa2_1 150;
    pos @aa2 150;
    pos @45646456 0;
    pos @aa22 0;
    pos @aa3 175;
    pos @ads 125;
    pos @adb 50;
    pos @ada 50;
    pos @adl 150;
} SA_alefmadda;

lookup yeh1 { # GSUB lookup type SingleSubstitution
    lookupflag RightToLeft;
    sub @group-dotless-7 by @group-dotless-4;
} yeh1;

lookup yeh1_1 { # GSUB lookup type SingleSubstitution
    lookupflag RightToLeft;
    sub @group-dotless-3 by @group_dotless_5;
} yeh1_1;

lookup SA_alefhamza { # GPOS lookup type SingleAdjustment
    pos alefmaddaabove-arab 50;
    pos alefhamzaabove-arab 50;
    pos @adl 50;
} SA_alefhamza;

lookup SingleSubstitution10 { # GSUB lookup type SingleSubstitution
    sub hah-arab.fina by uE0A1;
